#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Load app metadata
source "$ROOT_DIR/APP_METADATA"

# Check for vcpkg
if [[ -z "${VCPKG_ROOT:-}" ]]; then
    if [[ -d "$HOME/vcpkg" ]]; then
        export VCPKG_ROOT="$HOME/vcpkg"
    else
        echo "Error: vcpkg not found. Install it with:"
        echo "  git clone https://github.com/microsoft/vcpkg.git ~/vcpkg"
        echo "  ~/vcpkg/bootstrap-vcpkg.sh"
        exit 1
    fi
fi
echo "Using vcpkg at: $VCPKG_ROOT"

# Parse arguments
BUILD_TYPE="Debug"
BUILD_DIR="$ROOT_DIR/build"
RECONFIGURE=false
for arg in "$@"; do
    case "$arg" in
        release) BUILD_TYPE="Release"; BUILD_DIR="$ROOT_DIR/build_release" ;;
        --reconfigure) RECONFIGURE=true ;;
    esac
done
BUILD_DIR="${BUILD_DIR_OVERRIDE:-$BUILD_DIR}"
GENERATOR="${CMAKE_GENERATOR:-Unix Makefiles}"

# Only run cmake configure if build dir doesn't exist or CMakeCache is missing
if [[ ! -f "$BUILD_DIR/CMakeCache.txt" ]] || [[ "$RECONFIGURE" == true ]]; then
    echo "Configuring CMake (${BUILD_TYPE}, ${GENERATOR})..."
    cmake -S "$ROOT_DIR" -B "$BUILD_DIR" -G "$GENERATOR" -DCMAKE_BUILD_TYPE="$BUILD_TYPE"
else
    echo "Skipping CMake configure (already configured). Use --reconfigure to force."
fi

echo "Building DearSQL..."
cmake --build "$BUILD_DIR" --target dearsql

if [[ "$(uname)" == "Darwin" ]]; then
    echo "Build complete: $BUILD_DIR/DearSQL.app"
    exit 0
fi

echo "Build complete: $BUILD_DIR/dearsql"

# On Linux release builds, also produce .deb and AppImage
if [[ "$BUILD_TYPE" != "Release" ]]; then
    exit 0
fi

# ---- AppImage packaging ----
LINUXDEPLOY="$BUILD_DIR/linuxdeploy-x86_64.AppImage"
LINUXDEPLOY_URL="https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage"

# bundle the newer type2-runtime instead of the default one shipped by
# linuxdeploy. the old runtime segfaults on modern Arch / FUSE3 systems
# right after process init (see issue #16) — the type2-runtime supports
# both FUSE2/FUSE3 and falls back to extract-and-run when FUSE is unusable.
RUNTIME_FILE="$BUILD_DIR/appimage-runtime-x86_64"
RUNTIME_URL="https://github.com/AppImage/type2-runtime/releases/download/continuous/runtime-x86_64"

if [[ ! -x "$LINUXDEPLOY" ]]; then
    echo "Downloading linuxdeploy..."
    curl -fSL -o "$LINUXDEPLOY" "$LINUXDEPLOY_URL"
    chmod +x "$LINUXDEPLOY"
fi

if [[ ! -f "$RUNTIME_FILE" ]]; then
    echo "Downloading AppImage type2-runtime..."
    curl -fSL -o "$RUNTIME_FILE" "$RUNTIME_URL"
    chmod +x "$RUNTIME_FILE"
fi

APPDIR="$BUILD_DIR/AppDir"
APPIMAGE_FILE="$BUILD_DIR/${APP_NAME}-x86_64.AppImage"

echo "Packaging AppImage..."

rm -rf "$APPDIR"
mkdir -p "$APPDIR/usr/bin"
mkdir -p "$APPDIR/usr/share/applications"
mkdir -p "$APPDIR/usr/share/icons/hicolor/256x256/apps"

install -m755 "$BUILD_DIR/dearsql" "$APPDIR/usr/bin/dearsql"
install -m644 "$ROOT_DIR/packaging/$APP_IDENTIFIER.desktop" \
    "$APPDIR/usr/share/applications/$APP_IDENTIFIER.desktop"
install -m644 "$ROOT_DIR/assets/appicon.png" \
    "$APPDIR/usr/share/icons/hicolor/256x256/apps/$APP_IDENTIFIER.png"

OUTPUT="$APPIMAGE_FILE" LDAI_RUNTIME_FILE="$RUNTIME_FILE" "$LINUXDEPLOY" \
    --appdir "$APPDIR" \
    --desktop-file "$APPDIR/usr/share/applications/$APP_IDENTIFIER.desktop" \
    --icon-file "$APPDIR/usr/share/icons/hicolor/256x256/apps/$APP_IDENTIFIER.png" \
    --output appimage

sha256sum "$APPIMAGE_FILE" > "${APPIMAGE_FILE}.sha256"
echo "AppImage created: $APPIMAGE_FILE"
